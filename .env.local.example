# Copia este archivo como .env.local y rellena.
# Usa las MISMAS credenciales del proyecto okami-consentimientos
# (supabase.com → tu proyecto → Settings → API)

NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# PIN de acceso rol Admin
NEXT_PUBLIC_APP_PIN=0000
# PIN de acceso rol Host (recepción) — elígelo tú, distinto al de admin
NEXT_PUBLIC_HOST_PIN=1111
# Los tatuadores entran con su PIN personal (columna pin de la tabla tatuadores)
